{
  "name": "bothouse",
  "version": "1.0.0",
  "description": "Scraper inmobiliario modular (Playwright + Excel + notificaciones)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --expose-gc --max-old-space-size=450 dist/index.js",
    "start:production": "NODE_ENV=production node --expose-gc --max-old-space-size=450 dist/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "scrape:site": "tsx src/scripts/run-site.ts",
    "ai:analyze": "tsx src/scripts/analyze-departamentos.ts",
    "generate:excel": "tsx src/scripts/generate-example-excel.ts",
    "build:previews": "tsx src/scripts/build-previews.ts",
    "test:scrapers": "tsx src/scripts/test-scrapers-and-preview.ts",
    "test:scrapers:h": "PLAYWRIGHT_HEADLESS=false tsx src/scripts/test-scrapers-and-preview.ts",
    "test:email": "tsx src/scripts/test-email.ts",
    "test": "echo \"tests pendientes\" && exit 0"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^6.10.2",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.27.2",
    "fastify-plugin": "^4.5.1",
    "googleapis": "^169.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.12",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.0",
    "playwright": "1.57.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3"
  }
}
